---
import { getEntry } from 'astro:content';

const contact = await getEntry('contact', 'index');
const c = contact?.data;
---

{c && (
  <>
    <section id="contact" class="contact-section">
      <div class="container">
        <div class="contact-inner">
          <h2 class="section-heading" set:html={c.headline} />
          <p class="contact-lead">{c.lead}</p>

          <div class="contact-actions">
            <a href={`mailto:${c.email}`} class="btn btn-primary">
              Say hello
            </a>
            <a
              href={c.resumeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost"
            >
              Download Résumé ↗
            </a>
          </div>

          <div class="contact-grid">
            <div class="contact-row">
              <span class="contact-label">Email</span>
              <a href={`mailto:${c.email}`}>{c.email}</a>
            </div>
            {c.phone && (
              <div class="contact-row">
                <span class="contact-label">Phone</span>
                <a href={`tel:${c.phone.replace(/\s+/g, '')}`}>{c.phone}</a>
              </div>
            )}
            {c.linkedin && (
              <div class="contact-row">
                <span class="contact-label">LinkedIn</span>
                <a href={c.linkedin} target="_blank" rel="noopener noreferrer">
                  {c.linkedin.replace(/^https?:\/\//, '')}
                </a>
              </div>
            )}
            {c.github && (
              <div class="contact-row">
                <span class="contact-label">GitHub</span>
                <a href={c.github} target="_blank" rel="noopener noreferrer">
                  {c.github.replace(/^https?:\/\//, '')}
                </a>
              </div>
            )}
            <div class="contact-row">
              <span class="contact-label">Location</span>
              <span>{c.location}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <div class="footer-brand">
            <strong>Vaibhav Raj</strong>
            <span>AI/ML Engineer · ATH Infosystems</span>
          </div>
          <div class="footer-links">
            <a href={`mailto:${c.email}`}>Email</a>
            {c.github && <a href={c.github} target="_blank" rel="noopener noreferrer">GitHub</a>}
            {c.linkedin && <a href={c.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>}
          </div>
          <p class="footer-copy">© 2026 Vaibhav Raj. Made with care.</p>
        </div>
      </div>
    </footer>
  </>
)}

<!-- Back-to-top -->
<button class="back-to-top" id="backToTop" aria-label="Back to top">
  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
    <path d="M9 15V3M9 3L3 9M9 3L15 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<!-- Image Zoom Modal -->
<div
  id="myModal"
  class="modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-caption"
  aria-hidden="true"
>
  <button class="close" aria-label="Close modal">&times;</button>
  <div class="modal-content">
    <img id="modalImage" src="" alt="" />
    <p id="modal-caption" class="modal-caption"></p>
  </div>
</div>
