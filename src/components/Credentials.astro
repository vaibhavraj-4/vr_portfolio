---
import { getCollection } from 'astro:content';

const certs = (await getCollection('certificates')).sort(
  (a, b) => a.data.order - b.data.order
);
const awards = (await getCollection('awards')).sort(
  (a, b) => a.data.order - b.data.order
);
const activities = (await getCollection('activities')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="credentials" class="credentials-section">
  <div class="container">
    <div class="credentials-head">
      <h2 class="section-heading">Credentials</h2>
      <p class="section-lead">
        Certificates, awards, and activities marking a path of continuous
        learning.
      </p>
    </div>

    {certs.length > 0 && (
      <div class="certificates" data-aos="fade-up">
        <h3 class="subsection-heading">Certificates</h3>
        {certs.map((c) => (
          <div class="certificate-item">
            <img
              src={c.data.image}
              alt={c.data.title}
              class="zoomable"
              onerror="this.style.display='none'"
            />
            <p>{c.data.title}{c.data.issuer ? ` — ${c.data.issuer}` : ''}</p>
            {c.data.link && (
              <a
                class="cert-link"
                href={c.data.link}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`View ${c.data.title}`}
              >
                <img src="/icons/link.png" alt="" onerror="this.style.display='none'" />
              </a>
            )}
          </div>
        ))}
      </div>
    )}

    {awards.length > 0 && (
      <div class="awards" data-aos="fade-up">
        <h3 class="subsection-heading">Awards</h3>
        {awards.map((a) => (
          <div class="award-item">
            <img
              src={a.data.image}
              alt={a.data.title}
              class="zoomable"
              onerror="this.style.display='none'"
            />
            <p>{a.data.title}</p>
            {a.data.link && (
              <a
                class="cert-link"
                href={a.data.link}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`View ${a.data.title}`}
              >
                <img src="/icons/link.png" alt="" onerror="this.style.display='none'" />
              </a>
            )}
          </div>
        ))}
      </div>
    )}

    {activities.length > 0 && (
      <div class="activities" data-aos="fade-up">
        <h3 class="subsection-heading">Activities</h3>
        {activities.map((a) => (
          <div class="activity-item">
            <img
              src={a.data.image}
              alt={a.data.title}
              class="zoomable"
              onerror="this.style.display='none'"
            />
            <p>{a.data.title}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
